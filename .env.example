# LINE
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LIFF_ID=
# Optional: explicit channel ID (defaults to LIFF_ID prefix before hyphen)
LINE_CHANNEL_ID=

# Google Gemini (free tier at aistudio.google.com)
GEMINI_API_KEY=
# Optional: gemini-2.0-flash (default) or gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# Database (Railway injects automatically)
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Cloudflare R2
CF_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=myassist-slips
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Google Calendar (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Finnhub (ข่าวหุ้น — สมัครฟรีที่ finnhub.io)
FINNHUB_API_KEY=

# Market scan speed (~320 symbols / 2 min → full ~37k universe in ~4 hrs)
SCAN_CONCURRENCY=8
SCAN_BATCH_SIZE=40
SCAN_BATCHES_PER_CRON=8
# Top picks snapshot: count + refresh interval (hours)
RECOMMENDATION_PICK_LIMIT=20
RECOMMENDATION_INTERVAL_HOURS=8
# Max US stocks from Finnhub supplement (0 = unlimited; primary US list from NASDAQ/NYSE)
US_SCAN_LIMIT=0
# Batch size for DB upsert when refreshing symbol list
DB_UPSERT_BATCH=500
# Buy signal threshold (0.35 = 35/100)
SIGNAL_BUY_THRESHOLD=0.35

# App
# Same Railway URL when frontend is bundled with backend (default Dockerfile)
FRONTEND_URL=https://your-app.up.railway.app
BACKEND_URL=https://your-app.up.railway.app
PORT=3000
NODE_ENV=production

# Local dev only — NEVER enable in production
# DEV_AUTH_BYPASS=true
# DEV_LINE_USER_ID=Uyour_line_user_id_here
