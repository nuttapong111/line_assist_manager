    "setup:richmenu": "ts-node src/scripts/setup-richmenu.ts",
    "setup:richmenu:prod": "node dist/scripts/setup-richmenu.js",
    "trigger:morning": "ts-node src/scripts/trigger-morning-summary.ts",
    "trigger:morning:prod": "node dist/scripts/trigger-morning-summary.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@google/generative-ai": "^0.24.1",
    "@line/bot-sdk": "^9.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "googleapis": "^173.0.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "sharp": "^0.35.1",
    "technicalindicators": "^3.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/sharp": "^0.31.1",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
