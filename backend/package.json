  "version": "1.0.0",
  "description": "MyAssist LINE Personal Assistant Backend",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/lib/migrate.js",
